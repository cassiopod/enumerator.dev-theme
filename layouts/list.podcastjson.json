{
	"version": "https://jsonfeed.org/version/1",
	"title": {{ .Site.Title | jsonify }},
	"icon": "{{ .Site.Params.author_avatar }}",
	"home_page_url": "{{ .Site.BaseURL }}",
	"feed_url": "{{ .Site.BaseURL }}podcast.json",
	"items": [
		{{- $list := where .Site.Pages ".Params.audio_with_metadata" "!=" nil -}}
		{{- $len := (len $list) -}}
		{{ range $index, $value := $list }}
			{
				"id": "{{ .Permalink }}",
				{{ if .Title -}}
				"title": {{ .Title | jsonify }},
				{{- end -}}
				{{- $s := .Content | jsonify -}}
				{{- $s := replace $s "\\u003c" "<" -}}
				{{- $s := replace $s "\\u003e" ">" -}}
				{{- $s := replace $s "\\u0026" "&" }}
				"content_html": {{ $s }},
				"date_published": "{{ .Date.Format "2006-01-02T15:04:05-07:00" }}",
				"url": "{{ .Permalink }}"
				{{- with .Params.categories -}}
				,
				"tags": {{ . | jsonify }}
				{{- end -}}
				{{- range first 1 .Params.audio_with_metadata -}},
				"attachments": [
					{
						"url": "{{ .url }}",
						"mime_type": "audio/mpeg"
					}
				]
				{{ end }}
			}
			{{- if ne (add $index 1) $len -}},{{- end -}}
		{{ end }}
	]
}
